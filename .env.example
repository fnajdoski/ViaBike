# --- RideCost API keys (all OPTIONAL — the app degrades gracefully without them) ---

# OpenRouteService — free key at https://openrouteservice.org/dev/#/signup
# Used for routing (driving-car profile, up to 50 waypoints).
# Without it, the app falls back to the public OSRM demo server (rate-limited,
# results labeled "demo routing — estimate").
ORS_API_KEY=

# TollGuru — free trial key at https://tollguru.com/developers
# Used for exact motorcycle-class tolls + a fuel-cost cross-check.
# Without it, tolls are estimated from a built-in per-country rate table
# and labeled "rough estimate".
TOLLGURU_API_KEY=

# MapTiler — optional, for prettier vector map tiles: https://www.maptiler.com/
# Without it, the map uses free CARTO dark raster tiles.
NEXT_PUBLIC_MAPTILER_KEY=
